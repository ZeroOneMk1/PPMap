# Copy this file to .env and fill in values. Never commit .env.

# Port the API listens on. Most platforms set this for you.
PORT=8000

# Connection string for MongoDB. In production, require auth and TLS.
MONGODB_URL=mongodb://localhost:27017/PPMapDB

# JWT signing key. 32+ random bytes. Generate with:
#   openssl rand -hex 32
# If unset or shorter than 32 chars, the server refuses to start.
JWT_SECRET=

# Cost factor for bcrypt. 12 is the recommended baseline.
BCRYPT_SALT_ROUNDS=12

# Origin allowed by CORS. The client URL.
# In dev this defaults to http://localhost:3000 if unset.
CLIENT_ORIGIN=http://localhost:3000

# Set to "production" to enable the HTTPS redirect, the Secure cookie flag,
# and the rate limiter's reverse-proxy IP handling.
# NODE_ENV=production
